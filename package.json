{
  "name": "monofocus",
  "version": "1.2.0",
  "description": "A minimal monochrome Pomodoro timer for Windows 11.",
  "main": "./out/main/index.js",
  "author": "MonoFocus",
  "license": "MIT",
  "scripts": {
    "postinstall": "install-electron",
    "icon:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "prebuild": "npm run icon:build",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.5"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.monofocus.desktop",
    "productName": "MonoFocus",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "extension",
        "to": "browser-extension"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MonoFocus-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
